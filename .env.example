# ================================================
# 环境变量配置文件
# 复制此文件为 .env 并填写实际值
# ================================================

# 服务器配置
NODE_ENV=development
PORT=3000

# 邮件服务(可选 - 用于发送通知)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@techcorp.com

# 数据库配置(可选 - 后期添加)
MONGODB_URI=mongodb://localhost:27017/techcorp
DATABASE_URL=

# 管理员令牌(生产环境改为安全的密钥)
ADMIN_TOKEN=your-secret-admin-token

# 前端URL(CORS配置)
FRONTEND_URL=http://localhost:3000
